# Copy this file to a file named `.env` (same folder as this example, or repo root).
# Django loads `H12/.env` and `backend/.env` (backend wins if both set a key).
# `.env.example` is NOT loaded — rename/copy to `.env` with your real key.
# Never commit the real `.env` file.
#
# With Django DEBUG=True, if GOOGLE_API_KEY is omitted the chatbot returns a short demo answer.
# In production (DEBUG=False) the key is required.
GOOGLE_API_KEY=
# Optional: force a specific model
# GEMINI_MODEL=gemini-2.0-flash

# Optional: path to fish YOLO ONNX model (default: backend/yolo_model/best.onnx)
# FISH_YOLO_MODEL_PATH=C:\path\to\best.onnx
# Optional: inference letterbox size (default 640). Lower = faster CPU (e.g. 512).
# FISH_YOLO_IMGSZ=640
# Optional: cap PyTorch CPU threads (e.g. 4) if the machine feels sluggish.
# FISH_YOLO_TORCH_THREADS=4
# Optional: confidence threshold override for predict (leave unset for Ultralytics default).
# FISH_YOLO_CONF=0.25
